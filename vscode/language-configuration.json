{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\[node:",
      "end": "^\\s*(\\[|$)"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*\\[(node|target):",
    "decreaseIndentPattern": "^\\s*\\["
  }
}
