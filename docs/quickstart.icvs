#project: "instructcanvas-quickstart"

# ── Quickstart Guide ───────────────────────────────────────
# Cara memulai dengan InstructCanvas dalam 5 menit.

[node: install_cli]
  type = action
  content = "Install CLI: cargo install icvs, atau download binary dari GitHub Releases."

[node: create_first]
  type = action
  content = "Buat file rules.icvs. Minimal: [node: name] type = rule, content = '...', severity = must."

[node: validate]
  type = action
  content = "Jalankan: icvs validate rules.icvs. Pastikan tidak ada error atau cycle."

[node: add_edge]
  type = action
  content = "Tambah edge: [edge: node_a -> node_b] untuk mendefinisikan dependency graph."

[node: add_target]
  type = action
  content = "Tambah target: [target: claude] resolve = [node_a, node_b]. Export: icvs export --target claude rules.icvs > CLAUDE.md"

[node: modularize]
  type = action
  content = "Pisahkan aturan ke multiple file: [include: './style.icvs'], [include: './security.icvs']"

[node: add_condition]
  type = action
  content = "Tambah conditional: [node: check] type = condition, if = $BRANCH == 'main', then = -> strict, else = -> relaxed."

[edge: install_cli -> create_first]
[edge: create_first -> validate]
[edge: validate -> add_edge]
[edge: add_edge -> add_target]
[edge: add_target -> modularize]
[edge: modularize -> add_condition]

[target: beginner]
  resolve = [
    install_cli, create_first, validate,
    add_edge, add_target, modularize, add_condition
  ]
